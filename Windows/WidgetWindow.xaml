<Window x:Class="WinWidgetBattery.Windows.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinWidgetBattery.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Title="Battery Widget">

    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu Background="#FF1E1E2E" BorderBrush="#FF454570">
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#FFCDD6F4"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="⚙  Settings"      Click="Settings_Click"/>
            <MenuItem Header="?  About"          Click="About_Click"/>
            <Separator Background="#FF454570"/>
            <MenuItem x:Name="RemoveMenuItem"
                      Header="✕  Remove Widget"  Click="Remove_Click"/>
            <Separator Background="#FF454570"/>
            <MenuItem Header="✕  Exit"           Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="WidgetBorder"
            Background="#CC1E1E2E"
            BorderBrush="#FF454570"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20,14,20,14"
            Cursor="Hand"
            MouseLeftButtonDown="Widget_MouseLeftButtonDown"
            MouseMove="Widget_MouseMove"
            MouseLeftButtonUp="Widget_MouseLeftButtonUp"
            MouseEnter="Widget_MouseEnter"
            MouseLeave="Widget_MouseLeave">

        <StackPanel Orientation="Vertical">

            <!-- Title section (collapses as a unit) -->
            <StackPanel x:Name="TitleSection" Orientation="Vertical">
                <Grid x:Name="TitleBarGrid" Height="22" Margin="0,0,0,8" IsHitTestVisible="True">
                    <TextBlock x:Name="TitleText"
                               Text="🔋 Battery"
                               Foreground="#66FFFFFF"
                               FontSize="11"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <StackPanel x:Name="IconPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Visibility="Collapsed"
                                IsHitTestVisible="True">
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="⚙"
                                ToolTip="Settings"
                                Click="Settings_Click"
                                IsHitTestVisible="True"/>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="?"
                                ToolTip="About"
                                FontWeight="Bold"
                                Margin="3,0,0,0"
                                Click="About_Click"
                                IsHitTestVisible="True"/>
                    </StackPanel>
                </Grid>
                <Rectangle x:Name="TitleBarSeparator" Height="1" Fill="#33FFFFFF" Margin="0,0,0,8" IsHitTestVisible="False"/>
            </StackPanel>

            <!-- Battery Display -->
            <Grid x:Name="BatteryContentGrid" Margin="0,6" IsHitTestVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Battery info: icon, percentage, status, time -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                        <TextBlock x:Name="BatteryIconText"
                                   Text="🔋"
                                   Foreground="#FFCDD6F4"
                                   FontSize="24"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="BatteryPercentText"
                                   Text=" ---%"
                                   Foreground="#FFCDD6F4"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   FontFamily="Consolas, Courier New"
                                   IsHitTestVisible="False"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               Text="Status: Unknown"
                               Foreground="#FF8787A1"
                               FontSize="10"
                               Margin="0,4,0,0"
                               IsHitTestVisible="False"/>
                    <TextBlock x:Name="TimeRemainingText"
                               Text=""
                               Foreground="#FF8787A1"
                               FontSize="9"
                               Margin="0,2,0,0"
                               IsHitTestVisible="False"/>
                </StackPanel>

                <!-- Battery bar (collapses when hidden, reclaims horizontal space) -->
                <StackPanel x:Name="BatteryBarContainer" Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False">
                    <Border Background="#33454570" CornerRadius="4" Height="20" Width="80" IsHitTestVisible="False">
                        <Border x:Name="BatteryBar"
                                Background="#FF00AA00"
                                CornerRadius="2"
                                Height="18"
                                Margin="1"
                                HorizontalAlignment="Left"
                                Width="78"
                                IsHitTestVisible="False"/>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</Window>
