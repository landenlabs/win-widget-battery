<Window x:Class="WinWidgetBattery.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinWidgetBattery — Settings"
        Width="500" Height="400"
        MinWidth="450" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        Background="#FF181825"
        Foreground="#FFCDD6F4"
        WindowStyle="SingleBorderWindow"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Widget Appearance Settings -->
        <Border Grid.Row="0" Background="#FF1E1E2E" Margin="16,16,16,0" CornerRadius="6" Padding="16">
            <StackPanel>

                <!-- Label -->
                <TextBlock Text="Widget Appearance"
                           Foreground="#FF89B4FA" FontWeight="SemiBold" FontSize="12"
                           Margin="0,0,0,16"/>

                <!-- Background color row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Background Color:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <Border x:Name="BgColorSwatch"
                            Width="42" Height="28"
                            CornerRadius="4"
                            Background="{Binding BgColorBrush}"
                            BorderBrush="#FF454570" BorderThickness="1"
                            Cursor="Hand"
                            Margin="0,0,12,0"
                            MouseLeftButtonDown="BgColorSwatch_Click"
                            ToolTip="Click to change background color"/>
                    <Button Content="Change…"
                            Style="{StaticResource SubtleButton}"
                            Padding="10,5"
                            Click="BgColorSwatch_Click"/>
                    <TextBlock x:Name="ColorHexLabel"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF6C7086"
                               FontSize="11"
                               FontFamily="Consolas, Courier New"/>
                </StackPanel>

                <!-- Opacity row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Opacity:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <Slider x:Name="OpacitySlider"
                            Width="150"
                            Minimum="0" Maximum="100"
                            Value="{Binding BgOpacityPercent, Mode=TwoWay}"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"/>
                    <TextBlock Margin="12,0,0,0" Width="40"
                               VerticalAlignment="Center"
                               Foreground="#FF89B4FA" FontWeight="SemiBold"
                               Text="{Binding BgOpacityPercent, StringFormat={}{0}%}"/>
                </StackPanel>

                <!-- Update Interval row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock Text="Update Interval:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <TextBox x:Name="UpdateIntervalBox"
                             Style="{StaticResource DarkTextBox}"
                             Width="80"
                             Text="{Binding UpdateInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Milliseconds between battery status updates"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="#FF6C7086" FontSize="11"
                               Text="ms"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Height="1" Fill="#FF454570" Margin="16,12,16,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
            <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK"     Style="{StaticResource AccentButton}"
                    Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
