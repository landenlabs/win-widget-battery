<Window x:Class="WinWidgetBattery.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinWidgetBattery — Settings"
        Width="500"
        MinWidth="450"
        SizeToContent="Height"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="#FF181825"
        Foreground="#FFCDD6F4"
        WindowStyle="SingleBorderWindow"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Widget Appearance -->
        <Border Grid.Row="0" Background="#FF1E1E2E" Margin="16,16,16,0" CornerRadius="6" Padding="16">
            <StackPanel>

                <TextBlock Text="Widget Appearance"
                           Foreground="#FF89B4FA" FontWeight="SemiBold" FontSize="12"
                           Margin="0,0,0,16"/>

                <!-- Background color row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Background Color:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <Border x:Name="BgColorSwatch"
                            Width="42" Height="28"
                            CornerRadius="4"
                            Background="{Binding BgColorBrush}"
                            BorderBrush="#FF454570" BorderThickness="1"
                            Cursor="Hand"
                            Margin="0,0,12,0"
                            MouseLeftButtonDown="BgColorSwatch_Click"
                            ToolTip="Click to change background color"/>
                    <Button Content="Change…"
                            Style="{StaticResource SubtleButton}"
                            Padding="10,5"
                            Click="BgColorSwatch_Click"/>
                    <TextBlock x:Name="ColorHexLabel"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF6C7086"
                               FontSize="11"
                               FontFamily="Consolas, Courier New"/>
                </StackPanel>

                <!-- Opacity row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Opacity:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <Slider x:Name="OpacitySlider"
                            Width="150"
                            Minimum="0" Maximum="100"
                            Value="{Binding BgOpacityPercent, Mode=TwoWay}"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"/>
                    <TextBlock Margin="12,0,0,0" Width="40"
                               VerticalAlignment="Center"
                               Foreground="#FF89B4FA" FontWeight="SemiBold"
                               Text="{Binding BgOpacityPercent, StringFormat={}{0}%}"/>
                </StackPanel>

                <!-- Font Scale row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Font Scale:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <Slider x:Name="FontScaleSlider"
                            Width="150"
                            Minimum="50" Maximum="200"
                            Value="{Binding FontScalePercent, Mode=TwoWay}"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"/>
                    <TextBlock Margin="12,0,0,0" Width="44"
                               VerticalAlignment="Center"
                               Foreground="#FF89B4FA" FontWeight="SemiBold"
                               Text="{Binding FontScalePercent, StringFormat={}{0}%}"/>
                </StackPanel>

                <!-- Update Interval row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Update Interval:" Foreground="#FFA6ADC8" VerticalAlignment="Center" Margin="0,0,12,0" Width="120"/>
                    <TextBox x:Name="UpdateIntervalBox"
                             Style="{StaticResource DarkTextBox}"
                             Width="80"
                             Text="{Binding UpdateInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Milliseconds between battery status updates"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="#FF6C7086" FontSize="11"
                               Text="ms"/>
                </StackPanel>

                <!-- Embed in wallpaper row -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Embed in wallpaper layer (restart required)"
                              IsChecked="{Binding EmbedInWallpaper, Mode=TwoWay}"
                              Foreground="#FFA6ADC8"
                              VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Display Components -->
        <Border Grid.Row="1" Background="#FF1E1E2E" Margin="16,8,16,0" CornerRadius="6" Padding="16">
            <StackPanel>

                <TextBlock Text="Display Components"
                           Foreground="#FF89B4FA" FontWeight="SemiBold" FontSize="12"
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Component" Foreground="#FF6C7086" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Show" Foreground="#FF6C7086" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>

                    <Rectangle Grid.Row="1" Grid.ColumnSpan="2"
                               Height="1" Fill="#33FFFFFF" Margin="0,0,0,4"/>

                    <!-- Title -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Title" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="2" Grid.Column="1"
                               IsChecked="{Binding ShowTitle, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Battery Icon -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Battery Icon" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="3" Grid.Column="1"
                               IsChecked="{Binding ShowBatteryIcon, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Percentage -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Percentage" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="4" Grid.Column="1"
                               IsChecked="{Binding ShowPercentage, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Color Bar -->
                    <TextBlock Grid.Row="5" Grid.Column="0"
                               Text="Color Bar" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="5" Grid.Column="1"
                               IsChecked="{Binding ShowColorBar, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Status Text -->
                    <TextBlock Grid.Row="6" Grid.Column="0"
                               Text="Status Text" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="6" Grid.Column="1"
                               IsChecked="{Binding ShowStatusText, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Time Remaining -->
                    <TextBlock Grid.Row="7" Grid.Column="0"
                               Text="Time Remaining" Foreground="#FFA6ADC8" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="7" Grid.Column="1"
                               IsChecked="{Binding ShowTimeRemaining, Mode=TwoWay}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                </Grid>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="2" Height="1" Fill="#FF454570" Margin="16,12,16,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
            <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK"     Style="{StaticResource AccentButton}"
                    Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
